# Maintainer: AntheaLaffy
# Contributor: AntheaLaffy <2602914182@qq.com>
pkgname=vocal2midi-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="AI vocal-to-MIDI desktop tool (PyQt5 + ONNX Runtime, Linux x86_64 binary)"
url="https://github.com/AntheaLaffy/Vocal2Midi-for-linux"
license=('MIT')
arch=('x86_64')
options=(!strip)
source=(
  "https://github.com/AntheaLaffy/Vocal2Midi-for-linux/releases/download/v${pkgver}/Vocal2Midi-linux-amd64.tar.zst"
  "vocal2midi.desktop"
  "vocal2midi.png::https://raw.githubusercontent.com/AntheaLaffy/Vocal2Midi-for-linux/v${pkgver}/icon.png"
)
noextract=()
# No archive sources are kept as-is; the large tar.zst is auto-extracted by
# makepkg and the two helper files (.desktop, .png) are copied verbatim.

sha256sums=(
  'ab740c5fcdb072f776f49962813b33930fc18bf04a9bffc39a75ab8b24e68aa0'
  '2eee7b972f9ea19f150ee333e221857ed19522c7526683856f94711b45ab7f98'
  'ca784d2e2ae4b57a1f2eff7065a4f6c3612593be3b651b4e0c97279cd3615e51'
)

package() {
  cd "${srcdir}"

  # Install the bundled binary
  install -dm755 "${pkgdir}/opt/vocal2midi"
  cp -a --no-preserve=ownership,mode "Vocal2Midi"/* "${pkgdir}/opt/vocal2midi/"
  chmod -R u+rwX,go+rX "${pkgdir}/opt/vocal2midi"
  chmod 755 "${pkgdir}/opt/vocal2midi/Vocal2Midi"

  # Launcher symlink
  install -dm755 "${pkgdir}/usr/bin"
  ln -s "/opt/vocal2midi/Vocal2Midi" "${pkgdir}/usr/bin/vocal2midi"

  # Desktop entry
  install -Dm644 "${srcdir}/vocal2midi.desktop" \
    "${pkgdir}/usr/share/applications/vocal2midi.desktop"

  # Icons (freedesktop compliant locations)
  install -Dm644 "${srcdir}/vocal2midi.png" \
    "${pkgdir}/usr/share/icons/hicolor/256x256/apps/vocal2midi.png"
  install -Dm644 "${srcdir}/vocal2midi.png" \
    "${pkgdir}/usr/share/pixmaps/vocal2midi.png"

  # License
  if [[ -f "${srcdir}/Vocal2Midi/_internal/LICENSE" ]]; then
    install -Dm644 "${srcdir}/Vocal2Midi/_internal/LICENSE" \
      "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi
  install -Dm644 "${srcdir}/Vocal2Midi/_internal/ACKNOWLEDGEMENTS.md" \
    "${pkgdir}/usr/share/licenses/${pkgname}/ACKNOWLEDGEMENTS.md" 2>/dev/null || true
}
